# fzf config with Inklight colors
export FZF_DEFAULT_OPTS=" \
  --color=fg:#1b1b1b,bg:#f2f2f2,hl:#387200 \
  --color=fg+:#1b1b1b,bg+:#e5e5e5,hl+:#387200 \
  --color=info:#555555,prompt:#1b1b1b,pointer:#ac4b78 \
  --color=marker:#ac4b78,spinner:#9b1b60,header:#555555 \
  --color=border:#d7d7d7,gutter:#e5e5e5 \
  --border=rounded \
  --prompt='❯ ' \
  --pointer='▶'"

. "$HOME/.cargo/env"
