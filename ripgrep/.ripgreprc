# Search options
--column
--line-number
--smart-case

# Inklight magenta.fg1
--colors=path:fg:0x9b,0x1b,0x60

# Inklight blue.fg1
--colors=line:fg:0x00,0x4d,0xbb

# Inklight blue.fg2
--colors=column:fg:0x47,0x6f,0xb1

# Inklight green + bold
--colors=match:fg:0x38,0x72,0x00
--colors=match:style:bold
